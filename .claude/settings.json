{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -m code_review_graph update --skip-flows",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "python scripts/update_claude_md.py",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
